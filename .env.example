# LLM Configuration
LLM_PROVIDER=anthropic
LLM_MODE=api-key

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-proj-...

# Required when LLM_PROVIDER=deepseek
# DeepSeek uses direct API-key mode against the official API by default.
# DEEPSEEK_API_KEY=sk-...

# Optional: proxy mode (for CLIProxyAPI)
# LLM_MODE=setup-token
# LLM_PROXY_URL=http://localhost:8317

# Optional: model override
# Anthropic default: claude-sonnet-4-20250514
# OpenAI default: gpt-4.1-mini
# DeepSeek default: deepseek-v4-flash
# LLM_MODEL=claude-sonnet-4-20250514

# Optional: deep-dive paper input length limit (characters)
# Applies to Anthropic, OpenAI, and DeepSeek if set here.
# Default when unset:
# - Anthropic: 40000
# - OpenAI: 120000
# - DeepSeek: 120000
# PAPER_MAX_CHARS=120000

# Optional: deep-dive output token limit
# Applies to Anthropic, OpenAI, and DeepSeek if set here.
# Default when unset:
# - Anthropic: 8192
# - OpenAI: 12000
# - DeepSeek: 12000
# DEEP_DIVE_MAX_TOKENS=12000

# Data directories (defaults shown)
# DATA_DIR=data
# CONFIG_DIR=config

# --- Data Source API Keys ---

# YouTube Data API v3 (required for YouTube collector)
YOUTUBE_API_KEY=AIza...

# Tavily Search API (required for company blog monitoring)
TAVILY_API_KEY=tvly-...

# Product Hunt API (required for Product Hunt collector)
PRODUCT_HUNT_TOKEN=...

# Semantic Scholar API (optional, increases rate limits)
# SEMANTIC_SCHOLAR_API_KEY=

# GitHub Token (optional, increases rate limits)
# GITHUB_TOKEN=ghp_...
