# LLM Configuration
LLM_MODE=api-key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: proxy mode (for CLIProxyAPI)
# LLM_MODE=setup-token
# LLM_PROXY_URL=http://localhost:8317

# Optional: model override (default: claude-sonnet-4-20250514)
# LLM_MODEL=claude-sonnet-4-20250514

# Data directories (defaults shown)
# DATA_DIR=data
# CONFIG_DIR=config

# --- Data Source API Keys ---

# YouTube Data API v3 (required for YouTube collector)
YOUTUBE_API_KEY=AIza...

# Tavily Search API (required for company blog monitoring)
TAVILY_API_KEY=tvly-...

# Product Hunt API (required for Product Hunt collector)
PRODUCT_HUNT_TOKEN=...

# Semantic Scholar API (optional, increases rate limits)
# SEMANTIC_SCHOLAR_API_KEY=

# GitHub Token (optional, increases rate limits)
# GITHUB_TOKEN=ghp_...
